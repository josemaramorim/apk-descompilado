                        <Button android:id="@id/bt_light_save" android:layout_width="0.0px" android:layout_height="@dimen/button_height_normal" android:layout_marginLeft="@dimen/margin_normal" android:text="保存当前状态编号至文件" android:layout_weight="1.0" style="@style/button_normal_min150" />
