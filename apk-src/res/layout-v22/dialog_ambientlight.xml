                    </LinearLayout>
                    <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:layout_width="fill_parent" android:layout_height="wrap_content">
                        <TextView android:textSize="@dimen/font_normal" android:textStyle="bold" android:textColor="@color/white" android:gravity="center" android:id="@id/tv_light_blue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="@dimen/button_width_normal" android:text="蓝" />
                        <SeekBar android:id="@id/seek_light_blue" android:background="@color/white" android:paddingRight="@dimen/margin_large2" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginRight="@dimen/margin_large2" android:max="100" android:progress="0" android:min="0" />
