                            <RadioButton android:textSize="@dimen/font_normal" android:textStyle="bold" android:textColor="@color/black" android:id="@id/rb_light_stateno4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="饮品制作完成后8秒内，等待取杯中" />
                            <RadioButton android:textSize="@dimen/font_normal" android:textStyle="bold" android:textColor="@color/black" android:id="@id/rb_light_stateno5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="机器发生警告时" />
