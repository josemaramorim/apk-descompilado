        </LinearLayout>
        <LinearLayout android:gravity="center" android:orientation="horizontal" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/margin_large">
            <TextView android:text="@string/machine_received_cmd" style="@style/text_normal" />
            <TextView android:id="@id/tv_machine_receivecmd" android:layout_marginLeft="@dimen/margin_normal" android:text="00" style="@style/text_normal" />
        </LinearLayout>
        <LinearLayout android:gravity="center" android:orientation="horizontal" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/margin_large">
            <TextView android:text="@string/machien_parse_cmd_result" style="@style/text_normal" />
            <TextView android:id="@id/tv_machine_parsecmd" android:layout_marginLeft="@dimen/margin_normal" android:minHeight="@dimen/button_height_normal" android:text="00" style="@style/text_normal" />
        </LinearLayout>
