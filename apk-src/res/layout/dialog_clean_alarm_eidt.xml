        </LinearLayout>
        <TextView android:gravity="center" android:layout_gravity="center_horizontal" android:id="@id/tv_cleanalarm_save" android:layout_marginBottom="@dimen/margin_large" android:text="@string/save" style="@style/button_normal" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
