                <RadioButton android:textSize="@dimen/font_normal" android:textColor="@color/black" android:id="@id/rb_symbolposision_front" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/symbol_position_front" />
                <RadioButton android:textSize="@dimen/font_normal" android:textColor="@color/black" android:id="@id/rb_symbolposision_hind" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/symbol_position_hind" />
            </RadioGroup>
        </LinearLayout>
        <TextView android:id="@id/tv_symbolposision_sure" android:layout_width="fill_parent" android:layout_marginLeft="@dimen/margin_large" android:layout_marginRight="@dimen/margin_large" android:layout_marginBottom="@dimen/margin_large" android:text="@string/sure" android:layout_alignParentBottom="true" style="@style/button_normal" />
    </RelativeLayout>
</androidx.cardview.widget.CardView>
