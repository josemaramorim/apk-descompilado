<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView android:layout_width="fill_parent" android:layout_height="wrap_content" style="@style/cardview_normal"
  xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout android:orientation="vertical" android:layout_width="fill_parent" android:layout_height="wrap_content">
        <com.jetinno.widget.HeadBar android:id="@id/headbar" android:layout_width="fill_parent" android:layout_height="wrap_content" app:backgroundColor="@color/colorPrimary" app:titleText="@string/自定义查询设置参数" />
        <View android:background="@color/white" android:layout_width="fill_parent" android:layout_height="@dimen/line_height_normal" />
        <LinearLayout android:orientation="horizontal" android:padding="@dimen/margin_large2" android:layout_width="fill_parent" android:layout_height="wrap_content">
            <EditText android:textSize="@dimen/font_small" android:id="@id/et_machine_data_address" android:hint="@string/machine_hint_configparams_address" android:maxLength="4" style="@style/input_machinecustomer" />
            <View android:background="@color/transparent" android:layout_width="@dimen/margin_large" android:layout_height="1.0px" />
            <EditText android:textSize="@dimen/font_small" android:id="@id/et_machine_data_length" android:text="01" android:hint="@string/machine_hint_configparams_length" android:maxLength="2" style="@style/input_machinecustomer" />
        </LinearLayout>
        <TextView android:textSize="@dimen/font_normal" android:textColor="@color/white" android:id="@id/tv_machine_cmd" android:paddingLeft="@dimen/margin_large2" android:paddingRight="@dimen/margin_large2" android:layout_width="fill_parent" android:layout_height="wrap_content" />
        <TextView android:enabled="false" android:layout_gravity="center_horizontal" android:id="@id/tv_machine_sure" android:layout_marginTop="@dimen/margin_large2" android:layout_marginBottom="@dimen/margin_large2" android:text="@string/sure" style="@style/button_normal" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
