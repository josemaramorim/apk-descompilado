<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView android:layout_width="fill_parent" android:layout_height="fill_parent" style="@style/cardview_normal"
  xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout android:orientation="vertical" android:layout_width="fill_parent" android:layout_height="wrap_content">
        <com.jetinno.widget.HeadBar android:id="@id/headbar" android:layout_width="fill_parent" android:layout_height="wrap_content" app:backgroundColor="@color/colorPrimary" app:titleText="@string/common_qr_manager" />
        <LinearLayout android:orientation="horizontal" android:layout_width="fill_parent" android:layout_height="wrap_content">
            <LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="0.0dip" android:layout_height="@dimen/text_height_normal" android:layout_weight="1.0">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/common_pay_way" style="@style/text_canister" />
            </LinearLayout>
            <LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="0.0dip" android:layout_height="@dimen/text_height_normal" android:layout_weight="1.0">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/open_or_close" style="@style/text_canister" />
            </LinearLayout>
        </LinearLayout>
        <View android:background="@color/common_bg_gray2" android:layout_width="fill_parent" android:layout_height="@dimen/line_height_normal" />
        <androidx.recyclerview.widget.RecyclerView android:id="@id/rv_payswitch" android:layout_width="fill_parent" android:layout_height="0.0px" android:layout_weight="1.0" />
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@id/ll_payswitch_bottom_vessel" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/margin_normal" android:layout_marginBottom="@dimen/margin_large2">
            <TextView android:id="@id/tv_payswitch_checkall" android:layout_width="0.0px" android:text="@string/check_all" android:layout_weight="1.0" style="@style/button_normal" />
            <TextView android:id="@id/tv_payswitch_invert" android:layout_width="0.0px" android:layout_marginLeft="@dimen/margin_large" android:text="@string/uncheck_all" android:layout_weight="1.0" style="@style/button_normal" />
            <TextView android:id="@id/tv_payswitch_save" android:layout_width="0.0px" android:layout_marginLeft="@dimen/margin_large" android:text="@string/save" android:layout_weight="1.0" style="@style/button_normal" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
