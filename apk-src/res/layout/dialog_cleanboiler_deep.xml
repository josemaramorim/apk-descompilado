<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView android:layout_width="fill_parent" android:layout_height="fill_parent" style="@style/cardview_normal"
  xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout android:orientation="vertical" android:layout_width="fill_parent" android:layout_height="fill_parent">
        <com.jetinno.widget.HeadBar android:id="@id/headbar" android:layout_width="fill_parent" android:layout_height="wrap_content" app:backgroundColor="@color/colorPrimary" app:titleText="@string/clean_machine_empty_boiler_title" />
        <View android:background="@color/white" android:layout_width="fill_parent" android:layout_height="@dimen/line_height_normal" />
        <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@id/ll_cleanboiler_root" android:layout_width="fill_parent" android:layout_height="fill_parent">
            <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@id/ll_cleanboiler_selecttype" android:paddingLeft="@dimen/margin_large2" android:paddingRight="@dimen/margin_large2" android:layout_width="wrap_content" android:layout_height="wrap_content">
                <TextView android:textSize="@dimen/font_normal" android:textColor="@color/white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/请选择方式" />
                <TextView android:textSize="@dimen/font_normal" android:textColor="@color/white" android:id="@id/tv_cleanboiler_ioversion" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                <RadioGroup android:gravity="left" android:orientation="vertical" android:id="@id/rg_cleanboiler_selecttype" android:paddingTop="@dimen/margin_large2" android:paddingBottom="@dimen/margin_large2" android:layout_width="wrap_content" android:layout_height="wrap_content">
                    <RadioButton android:textSize="@dimen/font_normal" android:textColor="@color/white" android:id="@id/rb_cleanboiler_onlywater" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" android:button="@drawable/sel_check_white" android:text="@string/仅排水" />
                    <RadioButton android:textSize="@dimen/font_normal" android:textColor="@color/white" android:id="@id/rb_cleanboiler_watersteam" android:layout_width="wrap_content" android:layout_height="wrap_content" android:button="@drawable/sel_check_white" android:text="@string/排水吹气" />
                </RadioGroup>
                <Button android:id="@id/bt_cleanboiler_selecttype_next" android:layout_marginTop="@dimen/margin_normal" android:text="@string/next" style="@style/button_normal" />
            </LinearLayout>
            <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@id/ll_cleanboiler_step0" android:paddingLeft="@dimen/margin_large2" android:paddingRight="@dimen/margin_large2" android:layout_width="wrap_content" android:layout_height="wrap_content">
                <pl.droidsonroids.gif.GifImageView android:layout_width="@dimen/viewgroup_width_clean" android:layout_height="@dimen/viewgroup_width_clean" android:src="@drawable/gif_boiler_shrapnel" android:scaleType="fitXY" />
                <TextView android:textSize="@dimen/font_normal" android:textColor="@color/white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/clean_machine_empty_boiler_note2" />
                <Button android:id="@id/bt_cleanboiler_step0_next" android:layout_marginTop="@dimen/margin_normal" android:text="@string/next" style="@style/button_normal" />
            </LinearLayout>
            <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@id/ll_cleanboiler_step1" android:paddingLeft="@dimen/margin_large2" android:paddingRight="@dimen/margin_large2" android:layout_width="wrap_content" android:layout_height="wrap_content">
                <pl.droidsonroids.gif.GifImageView android:layout_width="@dimen/viewgroup_width_clean" android:layout_height="@dimen/viewgroup_width_clean" android:src="@drawable/gif_boiler_switch" android:scaleType="fitXY" />
                <TextView android:textSize="@dimen/font_normal" android:textColor="@color/white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/clean_machine_empty_boiler_note" />
                <Button android:id="@id/bt_cleanboiler_step1_next" android:layout_marginTop="@dimen/margin_normal" android:text="@string/next" style="@style/button_normal" />
            </LinearLayout>
            <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@id/ll_cleanboiler_step3" android:layout_width="wrap_content" android:layout_height="wrap_content">
                <ProgressBar android:layout_width="wrap_content" android:layout_height="wrap_content" />
                <TextView android:textSize="@dimen/font_normal" android:textColor="@color/white" android:id="@id/tv_cleanboiler_step3_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/margin_normal" android:text="@string/common_hint_pass_cleaning" />
                <Button android:id="@id/bt_cleanboiler_step3_next" android:layout_marginTop="@dimen/margin_normal" android:text="@string/完成" style="@style/button_normal" />
            </LinearLayout>
            <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@id/ll_cleanboiler_stop" android:layout_width="wrap_content" android:layout_height="wrap_content">
                <ProgressBar android:layout_width="wrap_content" android:layout_height="wrap_content" />
                <TextView android:textSize="@dimen/font_normal" android:textColor="@color/white" android:id="@id/tv_cleanburstdeep_stop" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/margin_normal" android:text="@string/clean_stop_cleaning" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
