        <TextView android:textColor="@color/white" android:id="@id/tv_end_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="@dimen/margin_large" android:text="5：30" android:paddingStart="@dimen/margin_large" android:paddingEnd="@dimen/margin_large" />
    </LinearLayout>
</LinearLayout>
