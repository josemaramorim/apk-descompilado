        <TextView android:textStyle="bold" android:textColor="@color/app_white" android:gravity="center" android:layout_width="0.0dip" android:layout_height="fill_parent" android:text="@string/common_machinelog_code" android:layout_weight="1.0" style="@style/text_canister" />
        <TextView android:textStyle="bold" android:textColor="@color/app_white" android:gravity="center" android:layout_width="0.0dip" android:layout_height="fill_parent" android:text="@string/common_machinelog_desc" android:layout_weight="1.0" style="@style/text_canister" />
        <TextView android:textStyle="bold" android:textColor="@color/app_white" android:gravity="center" android:layout_width="0.0dip" android:layout_height="fill_parent" android:text="@string/common_machinelog_help" android:layout_weight="1.0" style="@style/text_canister" />
