<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical" android:layout_width="fill_parent" android:layout_height="wrap_content"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:gravity="center_horizontal" android:orientation="horizontal" android:layout_width="fill_parent" android:layout_height="wrap_content">
        <TextView android:textSize="@dimen/font_normal" android:textStyle="bold" android:textColor="@color/white" android:id="@id/tv_step_number" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:textSize="@dimen/font_normal" android:textStyle="bold" android:textColor="@color/white" android:id="@id/tv_step_name" android:padding="@dimen/margin_normal" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:textSize="@dimen/font_normal" android:textStyle="bold" android:textColor="@color/white" android:id="@id/tv_step_time" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    </LinearLayout>
    <LinearLayout android:gravity="center_horizontal" android:orientation="horizontal" android:id="@id/ll_brew" android:visibility="gone" android:layout_width="fill_parent" android:layout_height="wrap_content">
        <TextView android:textSize="@dimen/font_normal" android:textColor="@color/white" android:id="@id/tv_brew" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/brew_time" />
        <TextView android:textSize="@dimen/font_normal" android:textColor="@color/white" android:id="@id/tv_brew_time" android:padding="@dimen/margin_normal" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    </LinearLayout>
    <LinearLayout android:gravity="center_horizontal" android:orientation="horizontal" android:id="@id/ll_flow_rate" android:visibility="gone" android:layout_width="fill_parent" android:layout_height="wrap_content">
        <TextView android:textSize="@dimen/font_normal" android:textColor="@color/white" android:id="@id/tv_flow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/brew_flow_rate" />
        <TextView android:textSize="@dimen/font_normal" android:textColor="@color/white" android:id="@id/tv_flow_rate" android:padding="@dimen/margin_normal" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    </LinearLayout>
</LinearLayout>
